{
  "pluginAlias": "EnerTalkKm81",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "EnerTalk(Encored) 전력 미터를 HomeKit 으로 노출합니다(read-only). 에너톡 앱 로그인 이메일/비밀번호만 있으면 됩니다. '실시간 전력'과 '당월 사용량'을 각각 켜고/끌 수 있고, 켜면 이름을 지정할 수 있습니다. 각 센서는 조도센서(lux) 로 홈 앱에 숫자가 뜨고, Eve 특성(W/kWh/V/A)+그래프도 함께 제공됩니다.",
  "footerDisplay": "developer.enertalk.com 이 폐쇄돼도 auth2/api2 는 동작합니다. client_id/secret 은 비워두면 앱 기본값을 사용합니다.",
  "schema": {
    "type": "object",
    "properties": {
      "email": {
        "title": "에너톡 이메일",
        "type": "string",
        "required": true,
        "format": "email"
      },
      "password": {
        "title": "에너톡 비밀번호",
        "type": "string",
        "required": true,
        "x-schema-form": { "type": "password" }
      },
      "exposePower": {
        "title": "실시간 전력 액세서리 추가",
        "type": "boolean",
        "default": true,
        "description": "현재 소비전력(W)을 조도센서 액세서리로 노출."
      },
      "powerSensorName": {
        "title": "실시간 전력 센서 이름",
        "type": "string",
        "default": "실시간 전력",
        "condition": { "functionBody": "return model.exposePower !== false;" }
      },
      "exposeUsage": {
        "title": "당월 사용량 액세서리 추가",
        "type": "boolean",
        "default": true,
        "description": "검침일 기준 당월 누적(kWh)을 조도센서 액세서리로 노출."
      },
      "usageSensorName": {
        "title": "당월 사용량 센서 이름",
        "type": "string",
        "default": "당월 사용량",
        "condition": { "functionBody": "return model.exposeUsage !== false;" }
      },
      "pollingInterval": {
        "title": "실시간 폴링 주기(초)",
        "type": "integer",
        "default": 30,
        "minimum": 10,
        "maximum": 3600,
        "description": "실시간 W 조회 주기. 권장 30~60초."
      },
      "billingInterval": {
        "title": "당월 사용량 폴링 주기(초)",
        "type": "integer",
        "default": 300,
        "minimum": 60,
        "maximum": 86400,
        "description": "당월 kWh/요금 조회 주기. 권장 300초."
      },
      "exposeOutlet": {
        "title": "Eve 에너지 그래프용 콘센트 추가 (선택)",
        "type": "boolean",
        "default": false,
        "description": "Eve 에너지 그래프 UI 용 Outlet. On 스위치가 필수라 홈 앱에 토글이 보이지만 동작은 없습니다. 보통 꺼둡니다."
      },
      "name": {
        "title": "콘센트 액세서리 이름",
        "type": "string",
        "default": "소비전력",
        "condition": { "functionBody": "return model.exposeOutlet === true;" }
      },
      "clientId": {
        "title": "client_id (고급, 선택)",
        "type": "string"
      },
      "clientSecret": {
        "title": "client_secret (고급, 선택)",
        "type": "string",
        "x-schema-form": { "type": "password" }
      }
    },
    "required": ["email", "password"]
  }
}
